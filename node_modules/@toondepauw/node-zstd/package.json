{
  "name": "@toondepauw/node-zstd",
  "version": "2.0.0",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "node-zstd",
    "targets": [
      "x86_64-apple-darwin",
      "x86_64-pc-windows-msvc",
      "x86_64-unknown-linux-gnu",
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "aarch64-unknown-linux-musl",
      "x86_64-unknown-linux-musl"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "@napi-rs/cli": "^3.5.0",
    "@types/node": "^20.4.9",
    "ava": "^7.0.0"
  },
  "ava": {
    "timeout": "3m"
  },
  "engines": {
    "node": ">= 20"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "universal": "napi universalize",
    "version": "napi version && git add npm/"
  },
  "packageManager": "yarn@3.6.1",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/toondepauw/node-zstd.git"
  },
  "description": "Node.js addon for native Zstandard encoding and decoding with support for dictionaries.",
  "keywords": [
    "zstandard",
    "zstd",
    "compression",
    "decompression",
    "encoding",
    "decoding",
    "node",
    "nodejs",
    "node-addon",
    "node-api",
    "napi-rs",
    "rust"
  ],
  "optionalDependencies": {
    "@toondepauw/node-zstd-darwin-x64": "2.0.0",
    "@toondepauw/node-zstd-win32-x64-msvc": "2.0.0",
    "@toondepauw/node-zstd-linux-x64-gnu": "2.0.0",
    "@toondepauw/node-zstd-darwin-arm64": "2.0.0",
    "@toondepauw/node-zstd-linux-arm64-gnu": "2.0.0",
    "@toondepauw/node-zstd-linux-arm64-musl": "2.0.0",
    "@toondepauw/node-zstd-linux-x64-musl": "2.0.0"
  }
}